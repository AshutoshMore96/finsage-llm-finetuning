# Copy to .env and fill in. Never commit the real .env.

# Path to the GGUF model the API serves (overrides config.yaml serve.gguf_path)
FINSAGE_GGUF=models/finsage-merged-16bit-gguf/finsage.Q4_K_M.gguf

# Optional: protect the API. If set, clients must send header X-API-Key: <value>
# (also set api.api_key in config/config.yaml or read it there)
FINSAGE_API_KEY=

# Hugging Face token (to push the model to the Hub)
HF_TOKEN=

# Anthropic API key (only for the optional LLM-as-judge evaluation)
ANTHROPIC_API_KEY=

# Weights & Biases (optional experiment tracking during training)
WANDB_API_KEY=
